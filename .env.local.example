# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
# CLAUDE_PARSE_MODEL=claude-haiku-4-5-20251001

# Stripe (add when ready for Pro tier)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ko-fi (optional — enables support link in app footer)
# NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/YOUR_USERNAME

# Sentry (optional — error monitoring in production)
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
